# GeneLens — environment variables. Copy to .env.local for local dev; never commit real values.
# All external calls are server-side only (Next.js API routes) — these keys never reach the client.

# NVIDIA NIM API key (free tier). Required for AI-synthesized explanations; without it the app
# still works and falls back to source-data-only responses (see src/lib/nim.ts).
NVIDIA_API_KEY=

# NIM model id to call. Optional — defaults to nvidia/llama-3.3-nemotron-super-49b-v1.5
# (see src/lib/version.ts). Only override with another NVIDIA NIM-hosted model id.
NIM_MODEL=
